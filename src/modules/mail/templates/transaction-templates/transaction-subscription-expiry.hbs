<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Subscription Expiring Soon</title>
  </head>
  <body
    style="margin:0;padding:0;background-color:#0a0a0a;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;"
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      role="presentation"
      style="background-color:#0a0a0a;padding:48px 16px;"
    >
      <tr><td align="center">
          <table
            width="560"
            cellpadding="0"
            cellspacing="0"
            role="presentation"
            style="max-width:560px;width:100%;background-color:#141414;border:1px solid #262626;border-radius:16px;overflow:hidden;"
          >

            <!-- Logo -->
            <tr><td style="padding:36px 40px 24px 40px;">
                <table cellpadding="0" cellspacing="0" role="presentation"><tr>
                    <td style="vertical-align:middle;">
                      <span
                        style="display:inline-block;width:32px;height:32px;background-color:#f97316;border-radius:8px;text-align:center;line-height:32px;color:#fff;font-weight:800;font-size:18px;"
                      >L</span>
                    </td>
                    <td style="vertical-align:middle;padding-left:10px;">
                      <span
                        style="color:#fff;font-size:20px;font-weight:700;letter-spacing:-0.5px;"
                      >lokerin</span>
                    </td>
                  </tr></table>
              </td></tr>

            <!-- Eyebrow -->
            <tr><td style="padding:0 40px;">
                <p
                  style="margin:0;color:#f97316;font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;"
                >
                  Subscription Reminder
                </p>
              </td></tr>

            <!-- Heading -->
            <tr><td style="padding:12px 40px 0 40px;">
                <h1
                  style="margin:0;color:#fff;font-size:30px;font-weight:800;line-height:1.2;letter-spacing:-1px;"
                >
                  Hi
                  {{name}},<br />your subscription<br />expires tomorrow.
                </h1>
              </td></tr>

            <!-- Body -->
            <tr><td style="padding:20px 40px 0 40px;">
                <p
                  style="margin:0;color:#a3a3a3;font-size:16px;line-height:1.6;"
                >
                  Your
                  <strong style="color:#fff;">{{planName}}</strong>
                  subscription will expire on
                  <strong style="color:#f97316;">{{endDate}}</strong>. Renew now
                  to keep access to all exclusive features.
                </p>
              </td></tr>

            <!-- Info box -->
            <tr><td style="padding:24px 40px 0 40px;">
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  role="presentation"
                  style="background-color:#1c1c1c;border:1px solid #2a2a2a;border-radius:10px;"
                >
                  <tr><td style="padding:14px 16px;">
                      <p
                        style="margin:0;color:#d4d4d4;font-size:13px;line-height:1.5;"
                      >
                        ⚡ Renew before it expires to avoid losing access to CV
                        Generator, Skill Assessments, and more.
                      </p>
                    </td></tr>
                </table>
              </td></tr>

            <!-- CTA -->
            <tr><td style="padding:32px 40px 0 40px;">
                <table cellpadding="0" cellspacing="0" role="presentation"><tr>
                    <td style="background-color:#f97316;border-radius:10px;">
                      <a
                        href="{{subscribeUrl}}"
                        target="_blank"
                        style="display:inline-block;padding:14px 36px;color:#fff;font-size:16px;font-weight:700;text-decoration:none;"
                      >
                        Renew Now &rarr;
                      </a>
                    </td>
                  </tr></table>
              </td></tr>

            <!-- Divider -->
            <tr><td style="padding:32px 40px 0 40px;">
                <div style="border-top:1px solid #262626;"></div>
              </td></tr>

            <!-- Footer -->
            <tr><td style="padding:24px 40px 36px 40px;">
                <p
                  style="margin:0;color:#525252;font-size:12px;line-height:1.5;"
                >
                  © Lokerin — Built for Gen Z. Made in Indonesia.
                </p>
              </td></tr>

          </table>
        </td></tr>
    </table>
  </body>
</html>
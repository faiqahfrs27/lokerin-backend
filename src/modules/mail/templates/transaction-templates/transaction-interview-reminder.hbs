<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Interview Reminder</title>
  </head>
  <body
    style="margin:0;padding:0;background-color:#0a0a0a;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;"
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      role="presentation"
      style="background-color:#0a0a0a;padding:48px 16px;"
    >
      <tr><td align="center">
          <table
            width="560"
            cellpadding="0"
            cellspacing="0"
            role="presentation"
            style="max-width:560px;width:100%;background-color:#141414;border:1px solid #262626;border-radius:16px;overflow:hidden;"
          >
            <tr><td style="padding:36px 40px 24px 40px;">
                <table cellpadding="0" cellspacing="0" role="presentation"><tr>
                    <td style="vertical-align:middle;">
                      <span
                        style="display:inline-block;width:32px;height:32px;background-color:#f97316;border-radius:8px;text-align:center;line-height:32px;color:#fff;font-weight:800;font-size:18px;"
                      >L</span>
                    </td>
                    <td style="vertical-align:middle;padding-left:10px;">
                      <span
                        style="color:#fff;font-size:20px;font-weight:700;letter-spacing:-0.5px;"
                      >lokerin</span>
                    </td>
                  </tr></table>
              </td></tr>
            <tr><td style="padding:0 40px;">
                <p
                  style="margin:0;color:#f97316;font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;"
                >Interview Reminder</p>
              </td></tr>
            <tr><td style="padding:12px 40px 0 40px;">
                <h1
                  style="margin:0;color:#fff;font-size:28px;font-weight:800;line-height:1.2;letter-spacing:-1px;"
                >Hi {{name}},<br />your interview is tomorrow.</h1>
              </td></tr>
            <tr><td style="padding:20px 40px 0 40px;">
                <p
                  style="margin:0;color:#a3a3a3;font-size:15px;line-height:1.6;"
                >
                  Quick reminder — interview with
                  {{companyName}}
                  for the
                  <strong style="color:#fff;">{{jobTitle}}</strong>
                  position is happening tomorrow.
                </p>
              </td></tr>
            <tr><td style="padding:24px 40px 0 40px;">
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  role="presentation"
                  style="background-color:#1f1f1f;border:1px solid #2a2a2a;border-radius:10px;"
                >
                  <tr><td style="padding:16px 18px;">
                      <p
                        style="margin:0 0 4px 0;color:#737373;font-size:11px;letter-spacing:1px;text-transform:uppercase;"
                      >When</p>
                      <p
                        style="margin:0;color:#fff;font-size:15px;font-weight:600;"
                      >{{scheduledAt}}</p>
                    </td></tr>
                  {{#if location}}
                    <tr><td style="padding:0 18px 16px 18px;">
                        <p
                          style="margin:0 0 4px 0;color:#737373;font-size:11px;letter-spacing:1px;text-transform:uppercase;"
                        >Where</p>
                        <p
                          style="margin:0;color:#fff;font-size:15px;font-weight:600;"
                        >{{location}}</p>
                      </td></tr>
                  {{/if}}
                  {{#if notes}}
                    <tr><td style="padding:0 18px 16px 18px;">
                        <p
                          style="margin:0 0 4px 0;color:#737373;font-size:11px;letter-spacing:1px;text-transform:uppercase;"
                        >Notes</p>
                        <p
                          style="margin:0;color:#e5e5e5;font-size:14px;line-height:1.5;"
                        >{{notes}}</p>
                      </td></tr>
                  {{/if}}
                </table>
              </td></tr>
            <tr><td style="padding:28px 40px 0 40px;">
                <a
                  href="{{applicationUrl}}"
                  style="display:inline-block;background-color:#f97316;color:#fff;padding:14px 28px;border-radius:10px;text-decoration:none;font-weight:700;font-size:14px;"
                >View application</a>
              </td></tr>
            <tr><td style="padding:36px 40px 36px 40px;">
                <p
                  style="margin:0;color:#525252;font-size:12px;line-height:1.5;"
                >You're receiving this because you have an upcoming interview
                  with
                  {{companyName}}
                  on Lokerin.</p>
              </td></tr>
          </table>
        </td></tr>
    </table>
  </body>
</html>
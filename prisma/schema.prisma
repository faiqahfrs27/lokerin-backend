generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
  dev
}

enum Gender {
  male
  female
}

enum VerificationType {
  email_verification
  password_reset
}

enum ApplicationStatus {
  pending
  reviewed
  accepted
  rejected
}

enum Provider {
  CREDENTIALS
  GOOGLE
}

model Sample {
  id        Int       @id @default(autoincrement())
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("samples")
}

model SubscriptionPlan {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  price     Int
  features  String[]
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("subscription_plans")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  passwordHash  String         @map("password_hash")
  role          Role           @default(user)
  isVerified    Boolean        @default(false) @map("is_verified")
  provider      Provider       @default(CREDENTIALS)
  companyId     String?        @unique @map("company_id") @db.Uuid
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  profile             UserProfile?
  company             Company?             @relation(fields: [companyId], references: [id])
  passwordResetTokens PasswordResetToken[]
  verifications       Verification[]
  savedJobs           SavedJob[]
  applications        Application[]
  assessmentResults   AssessmentResult[]
  badgesEarned        BadgeEarned[]
  certificates        Certificate[]
  testAttempts        TestAttempt[]

  @@index([email])
  @@map("users")
}

model UserProfile {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @map("user_id") @db.Uuid
  fullName  String    @map("full_name")
  birthDate DateTime? @map("birth_date") @db.Date
  gender    Gender?
  education String?
  address   String?
  latitude  Decimal?  @db.Decimal(10, 7)
  longitude Decimal?  @db.Decimal(10, 7)
  photoUrl  String?   @map("photo_url")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  expiredAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("refresh_tokens")
}

model Verification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  token     String           @unique
  type      VerificationType
  expiresAt DateTime         @map("expires_at")
  used      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, type])
  @@map("verifications")
}

model Company {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  email          String   @unique
  phone          String?
  descriptionRte String?  @map("description_rte") @db.Text
  logoUrl        String?  @map("logo_url")
  city           String?
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)

  admin User? @relation
  jobs  Job[]

  @@map("companies")
}

model JobCategory {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  jobs Job[]

  @@map("job_categories")
}

model Job {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  categoryId  String    @map("category_id") @db.Uuid
  title       String
  description String    @db.Text
  bannerUrl   String?   @map("banner_url")
  city        String?
  salary      Decimal?  @db.Decimal(15, 2)
  tags        Json?
  deadline    DateTime?
  isPublished Boolean   @default(false) @map("is_published")
  hasTest     Boolean   @default(false) @map("has_test")
  createdAt   DateTime  @default(now()) @map("created_at")

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category         JobCategory       @relation(fields: [categoryId], references: [id])
  savedBy          SavedJob[]
  applications     Application[]
  preSelectionTest PreSelectionTest?

  @@index([companyId])
  @@index([categoryId])
  @@index([isPublished])
  @@map("jobs")
}

model SavedJob {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

model Application {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  jobId           String            @map("job_id") @db.Uuid
  cvUrl           String            @map("cv_url")
  expectedSalary  Decimal?          @map("expected_salary") @db.Decimal(15, 2)
  status          ApplicationStatus @default(pending)
  rejectionReason String?           @map("rejection_reason") @db.Text
  appliedAt       DateTime          @default(now()) @map("applied_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interview Interview?

  @@unique([userId, jobId])
  @@index([status])
  @@map("applications")
}

model SkillAssessment {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  skillCategory String    @map("skill_category")
  passingScore  Int       @default(75) @map("passing_score")
  durationMin   Int       @default(30) @map("duration_minutes")
  badgePhoto    String?   @map("badge_photo")
  isPublished   Boolean   @default(false) @map("is_published")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  questions         AssessmentQuestion[]
  assessmentResults AssessmentResult[]
  badgeEarneds      BadgeEarned[]
  certificates      Certificate[]

  @@index([isPublished])
  @@map("skill_assessments")
}

model AssessmentQuestion {
  id           String    @id @default(uuid()) @db.Uuid
  assessmentId String    @map("assessment_id") @db.Uuid
  question     String    @db.Text
  options      String[]
  correctIndex Int       @map("correct_index")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  assessment SkillAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("assessment_questions")
}

model AssessmentResult {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  assessmentId String    @db.Uuid
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  answers      Json?
  score        Int?
  passed       Boolean   @default(false)

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment SkillAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  badgeEarned BadgeEarned?
  certificate Certificate?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([assessmentId])
  @@map("assessment_results")
}

model BadgeEarned {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  assessmentResultId String   @unique @db.Uuid
  assessmentId       String   @db.Uuid
  earnedAt           DateTime @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  result     AssessmentResult @relation(fields: [assessmentResultId], references: [id], onDelete: Cascade)
  assessment SkillAssessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assessmentId])
  @@map("badges_earned")
}

model Certificate {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  assessmentResultId String   @unique @db.Uuid
  assessmentId       String   @db.Uuid
  code               String   @unique @default(uuid()) @db.Uuid
  qrUrl              String?  @map("qr_url")
  pdfUrl             String?  @map("pdf_url")
  issuedAt           DateTime @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  result     AssessmentResult @relation(fields: [assessmentResultId], references: [id], onDelete: Cascade)
  assessment SkillAssessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@map("certificates")
}

model PreSelectionTest {
  id              String   @id @default(uuid()) @db.Uuid
  jobId           String   @unique @map("job_id") @db.Uuid
  title           String
  description     String?  @db.Text
  passingScore    Int      @default(75) @map("passing_score")
  durationMinutes Int      @default(30) @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  job       Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  questions TestQuestion[]
  attempts  TestAttempt[]

  @@index([jobId])
  @@map("pre_selection_tests")
}

model TestQuestion {
  id           String   @id @default(uuid()) @db.Uuid
  testId       String   @map("test_id") @db.Uuid
  questionText String   @map("question_text") @db.Text
  options      String[]
  correctIndex Int      @map("correct_index")
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  test PreSelectionTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@map("test_questions")
}

model TestAttempt {
  id          String    @id @default(uuid()) @db.Uuid
  testId      String    @map("test_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  score       Int
  passed      Boolean
  answers     Json
  attemptedAt DateTime  @default(now()) @map("attempted_at")
  completedAt DateTime? @map("completed_at")

  test PreSelectionTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([userId])
  @@map("test_attempts")
}

model Interview {
  id            String   @id @default(uuid()) @db.Uuid
  applicationId String   @unique @map("application_id") @db.Uuid
  scheduledAt   DateTime @map("scheduled_at")
  location      String?
  notes         String?  @db.Text
  reminderSent  Boolean  @default(false) @map("reminder_sent")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@map("interviews")
}